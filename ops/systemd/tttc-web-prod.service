[Unit]
Description=TTTC Web production (Vite preview)
After=network.target tttc-api-prod.service

[Service]
Type=simple
User=arved
Group=arved
WorkingDirectory=/srv/tttc/prod/web
# Direct node + Vite CLI — avoids `npm run` under systemd (PATH / signal / PID issues).
ExecStart=/usr/bin/node node_modules/vite/bin/vite.js preview --host 0.0.0.0 --port 5174 --strictPort
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
