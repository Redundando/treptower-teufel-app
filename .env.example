# Local development — copy to .env and fill in real values.
# Do not commit .env

# Database (local PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tttc_dev

# NetXP Verein (members CSV mirror)
# NETXP_AUTH=NETXP_CLUB_ID#NETXP_USERNAME:NETXP_PASSWORD
# Example:
# NETXP_AUTH=7418#Arved:berlin111
# (We recommend using the exact format your NetXP requires.)

# Alternative (if you prefer separate parts instead of NETXP_AUTH):
# NETXP_PASSWORD=your-password

# Optional: app / API
# API authentication (JWT)
# JWT_SECRET_KEY is required for the auth endpoints to work.
JWT_SECRET_KEY=CHANGE_ME
# Optional: access token lifetime in seconds (default in config/app.toml is 30 days).
# JWT_ACCESS_TOKEN_SECONDS=2592000

# Optional: other app behavior
# DEBUG=true

# If you add staging-only usage from your machine later, use .env.staging (gitignored)
# and put staging DB URL and other staging secrets there.
